{
  "name": "decentralabs-marketplace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:critical": "jest --ci --runInBand src/app/__tests__ src/app/api src/utils/intents src/utils/webauthn",
    "cy:open": "node cypress/run-cypress.js open",
    "cy:run": "node cypress/run-cypress.js run",
    "test:e2e": "node cypress/run-e2e.js run",
    "test:e2e:ui": "node cypress/run-e2e.js open",
    "test:e2e:coverage": "nyc --reporter=lcov npm run test:e2e",
    "test:e2e:live": "npx cypress run --browser chrome --spec cypress/e2e/live-integration.cy.js",
    "test:integration:blob": "node scripts/run-vercel-blob-integration.js",
    "dev": "next dev --turbopack",
    "dev:turbo": "next dev --turbopack",
    "dev:webpack": "next dev",
    "dev:no-turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:lint:cypress": "jest src/__tests__/lint.cypress.test.js --runInBand",
    "generate-jwt-keys": "node scripts/generate-jwt-keys.js",
    "rotate-jwt-keys": "node scripts/rotate-jwt-keys.js",
    "show-vercel-keys": "node scripts/show-keys-for-vercel.js",
    "update-vercel-env": "node scripts/update-vercel-env.js",
    "pre-commit": "node scripts/pre-commit-check.js",
    "coverage:summary": "node scripts/coverage-report.js",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "audit:institution-provisioning": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/audit-institution-provisioning.js",
    "reconcile:institution-provisioning": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/reconcile-institution-provisioning.js"
  },
  "dependencies": {
    "@base-org/account": "~2.5.4",
    "@coinbase/wallet-sdk": "~4.3.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@gemini-wallet/core": "^0.3.2",
    "@safe-global/safe-apps-provider": "^0.18.6",
    "@safe-global/safe-apps-sdk": "~9.1.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tanstack/query-sync-storage-persister": "^5.101.3",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-query-devtools": "^5.101.3",
    "@tanstack/react-query-persist-client": "^5.101.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.5.0",
    "cookie": "^1.1.1",
    "date-fns": "^4.4.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "ethers": "^6.16.0",
    "i18n-iso-countries": "^7.14.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "porto": "^0.2.37",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-flags-select": "^2.5.0",
    "react-icons": "^5.6.0",
    "saml2-js": "^4.0.4",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.62.1",
    "undici": "^6.23.0",
    "viem": "^2.55.1",
    "wagmi": "^3.7.3",
    "@xmldom/xmldom": "^0.8.10",
    "xml-crypto": "^6.1.2",
    "xml2js": "^0.6.2",
    "xpath": "^0.0.34",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^4.0.3",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.39.5",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.17",
    "@types/saml2-js": "^3.0.4",
    "@types/xml2js": "^0.4.14",
    "baseline-browser-mapping": "^2.9.14",
    "cypress": "^15.18.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jest": "^29.15.4",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "nyc": "^18.0.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.16",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "axios": "1.18.0",
    "js-yaml": "^4.3.0",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "next": {
      "postcss": "8.5.10"
    },
    "xmlbuilder2": "4.0.3",
    "rimraf": "^6.1.3",
    "test-exclude": "8.0.0",
    "@paulmillr/qr": "npm:qr@^0.5.4"
  }
}
